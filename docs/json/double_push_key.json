{
  "title": "DoublePushKey5",
  "rules": [
    {
      "description": "Double-RightShift_Clipboard History",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "9",
              "modifiers": [
                "right_option",
                "right_gui"
              ]
            }
          ],
          "conditions": [
            {
              "type": "variable_if",
              "name": "right_shift pressed",
              "value": 1
            },
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.vmware\\.fusion$",
                "^com\\.vmware\\.horizon$",
                "^com\\.vmware\\.view$",
                "^com\\.parallels\\.desktop$",
                "^com\\.parallels\\.vm$",
                "^com\\.parallels\\.desktop\\.console$",
                "^org\\.virtualbox\\.app\\.VirtualBoxVM$",
                "^com\\.vmware\\.proxyApp\\.",
                "^com\\.parallels\\.winapp\\."
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "right_shift pressed",
                "value": 1
              }
            },
            {
              "key_code": "right_shift"
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "right_shift pressed",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "right_shift pressed",
                  "value": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "description": "Double-LeftShift_followlink",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "pointing_button": "button1",
              "modifiers": [
                "left_gui"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com.microsoft.VSCode$",
                "^com.googlecode.iterm2$"
              ]
            },
            {
              "type": "variable_if",
              "name": "left_shift pressed",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_shift",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "left_shift pressed",
                "value": 1
              }
            },
            {
              "key_code": "left_shift"
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "left_shift pressed",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "left_shift pressed",
                  "value": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "description": "Double-fn_send_ctrl-c",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "c",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com.microsoft.VSCode$",
                "^com.googlecode.iterm2$"
              ]
            },
            {
              "type": "variable_if",
              "name": "right_control_pressed",
              "value": 1
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "right_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "set_variable": {
                "name": "right_control_pressed",
                "value": 1
              }
            },
            {
              "apple_vendor_top_case_key_code": "keyboard_fn"
            }
          ],
          "to_delayed_action": {
            "to_if_invoked": [
              {
                "set_variable": {
                  "name": "right_control_pressed",
                  "value": 0
                }
              }
            ],
            "to_if_canceled": [
              {
                "set_variable": {
                  "name": "right_control_pressed",
                  "value": 0
                }
              }
            ]
          }
        }
      ]
    },
    {
      "title": "Space Double Press Copy",
      "rules": [
        {
          "description": "Space single press keeps normal space, double press sends Command+C in VSCode and iTerm2",
          "manipulators": [
            {
              "type": "basic",
              "from": {
                "key_code": "spacebar",
                "modifiers": {
                  "optional": [
                    "any"
                  ]
                }
              },
              "conditions": [
                {
                  "type": "frontmost_application_if",
                  "bundle_identifiers": [
                    "^com\\.microsoft\\.VSCode$",
                    "^com\\.googlecode\\.iterm2$"
                  ]
                },
                {
                  "type": "variable_if",
                  "name": "spacebar_pressed",
                  "value": 1
                }
              ],
              "to": [
                {
                  "key_code": "c",
                  "modifiers": [
                    "left_command"
                  ]
                },
                {
                  "set_variable": {
                    "name": "spacebar_pressed",
                    "value": 0
                  }
                }
              ]
            },
            {
              "type": "basic",
              "from": {
                "key_code": "spacebar",
                "modifiers": {
                  "optional": [
                    "any"
                  ]
                }
              },
              "conditions": [
                {
                  "type": "frontmost_application_if",
                  "bundle_identifiers": [
                    "^com\\.microsoft\\.VSCode$",
                    "^com\\.googlecode\\.iterm2$"
                  ]
                }
              ],
              "to": [
                {
                  "set_variable": {
                    "name": "spacebar_pressed",
                    "value": 1
                  }
                },
                {
                  "key_code": "spacebar"
                }
              ],
              "to_delayed_action": {
                "to_if_invoked": [
                  {
                    "set_variable": {
                      "name": "spacebar_pressed",
                      "value": 0
                    }
                  }
                ],
                "to_if_canceled": [
                  {
                    "set_variable": {
                      "name": "spacebar_pressed",
                      "value": 0
                    }
                  }
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}

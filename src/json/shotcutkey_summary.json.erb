{
    "title": "ShotCutKeySummary",
    "rules": [
        {
            "description": "ShotCutKeySummary",
            "manipulators": [
                {
                    "description": "RightCommand + A_NewFileCreate",
                    "type": "basic",
                    "from": <%= from("a", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["n", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "優先RightCommand + G_FileTabClose1",
                    "type": "basic",
                    "from": <%= from("g", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["w", ["right_command"]]]) %>
                },
                {
                    "description": "RightCommand + J_1RowSelection優先",
                    "type": "basic",
                    "from": <%= from("j", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["a", ["left_control"]], ["down_arrow", "left_shift"], ["c", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "rightcommand + K_CopyCurrentRowCut",
                    "type": "basic",
                    "from": <%= from("k", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["a", ["left_control"]], ["down_arrow", "left_shift"], ["c", ["right_command"]], ["delete_or_backspace"]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightCommand + L_NextTab",
                    "type": "basic",
                    "from": <%= from("l", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["tab", ["left_control", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightCommand + Q_Chrome_Tab_Get-SiteName-URL",
                    "type": "basic",
                    "from": <%= from("q", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["0", ["left_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightCommand + Semicolon_LatestTabToggle",
                    "type": "basic",
                    "from": <%= from("semicolon", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["tab", ["left_control"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightCommand + T_Search",
                    "type": "basic",
                    "from": <%= from("t", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["f", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + O(オー)_Save",
                    "type": "basic",
                    "from": <%= from("o", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["s", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftAlt + P_英語 → 日本語[DeepL + Alfred]",
                    "type": "basic",
                    "from": <%= from("p", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["8", ["left_shift","right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + S_AlfredHotkey",
                    "type": "basic",
                    "from": <%= from("s", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["spacebar", ["right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + W_UniversalActions",
                    "type": "basic",
                    "from": <%= from("w", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["backslash", ["left_option", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightAlt + C_Clipboardlist",
                    "type": "basic",
                    "from": <%= from("c", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["quote", ["right_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightAlt + F_AlfredArticleitemCall",
                    "type": "basic",
                    "from": <%= from("f", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["5", ["left_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightOption + O(オー)_名前を付けて保存",
                    "type": "basic",
                    "from": <%= from("o", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["s", ["right_shift", "right_command"]]]) %>
                },
                {
                    "description": "RightAlt + P_日本語 → 英語[DeepL + Alfred]",
                    "type": "basic",
                    "from": <%= from("p", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["0", ["left_shift","right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightOption + R_Record Screen/Stop Recording",
                    "type": "basic",
                    "from": <%= from("r", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["9", ["right_option", "right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightAlt + V_AlfredSnippetsCall",
                    "type": "basic",
                    "from": <%= from("v", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["quote", ["left_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightOption + Y_コレクションの表示/非表示",
                    "type": "basic",
                    "from": {
                        "key_code": "y",
                        "modifiers": {
                            "mandatory": [
                                "right_option"
                            ],
                            "optional": [
                                "caps_lock"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "5",
                            "modifiers": [
                                "right_command",
                                "right_option"
                            ]
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^com.vmware.fusion$",
                                "^com.vmware.horizon$",
                                "^com.vmware.view$",
                                "^com.parallels.desktop$",
                                "^com.parallels.vm$",
                                "^com.parallels.desktop.console$",
                                "^org.virtualbox.app.VirtualBoxVM$",
                                "^com.vmware.proxyApp.",
                                "^com.parallels.winapp."
                            ]
                        }
                    ]
                },
                {
                    "description": "LeftCommand + B_PageDown",
                    "type": "basic",
                    "from": <%= from("b", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["down_arrow", ["fn"]]]) %>
                },
                {
                    "description": "LeftCommand + C_DesktopExist",
                    "type": "basic",
                    "from": <%= from("c", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["q", ["right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + D_AllSelect",
                    "type": "basic",
                    "from": <%= from("d", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["a", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + E_Expand Selection Word",
                    "type": "basic",
                    "from": <%= from("e", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["right_arrow", ["left_control", "left_shift"]]]) %>
                },
                {
                    "description": "LeftCommand + M_EndRowCursol",
                    "type": "basic",
                    "from": <%= from("m", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["right_arrow", ["fn"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + N_HeadRowCursol",
                    "type": "basic",
                    "from": <%= from("n", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["left_arrow", ["fn"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + O(オ-)_スクショ(Replacekey)",
                    "type": "basic",
                    "from": <%= from("o", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["semicolon", ["left_command", "left_control","left_option"]]]) %>
                },
                {
                    "description": "LeftCommand + P_Yoinkを手動で表示",
                    "type": "basic",
                    "from": <%= from("p", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["f8", ["left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("pararell") %>]
                },
                {
                    "description": "LeftCommand + Period_AppsSelect-Next",
                    "type": "basic",
                    "from": <%= from("period", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["tab", "right_command"]]) %>
                },
                {
                    "description": "LeftCommand + S_Cut",
                    "type": "basic",
                    "from": <%= from("s", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["x", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + semicolon_CurrentRowCursolEnd1",
                    "type": "basic",
                    "from": <%= from("semicolon", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["e", ["right_control"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "LeftCommand + Slash_PageUp",
                    "type": "basic",
                    "from": <%= from("slash", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["up_arrow", ["fn"]]]) %>
                },
                {
                    "description": "LeftCommand + U_Undo",
                    "type": "basic",
                    "from": <%= from("u", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["z", ["left_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + V_AppClose",
                    "type": "basic",
                    "from": <%= from("v", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["q", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "LeftCommand + W_CurrentCursol-EndRowSelect",
                    "type": "basic",
                    "from": <%= from("w", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["e", ["left_shift", "left_control"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "LeftCommand + Y_やり直し",
                    "type": "basic",
                    "from": <%= from("y", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["z", ["left_shift" ,"left_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftCommand + Z_Pause/Resume Recording",
                    "type": "basic",
                    "from": <%= from("z", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["8", ["right_option", "right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftShift + F12_CaptureFullscreen",
                    "type": "basic",
                    "from": <%= from("f12", ["left_shift"], ["caps_lock"]) %>,
                    "to": <%= to([["1", ["left_shift", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                }
            ]
        }
    ]
}

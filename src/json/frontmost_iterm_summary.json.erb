{
    "title": "FrontmostIfIterm_summary4",
    "rules": [
        {
            "description": "FrontmostIfIterm_summary4",
            "manipulators": [
                {
                    "description": "LeftCommand + B_PageDown",
                    "type": "basic",
                    "from": <%= from("b", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["3", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftCommand + O(オー)_SplitVertically",
                    "type": "basic",
                    "from": <%= from("o", ["left_control"]) %>,
                    "to": <%= to([["d", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftCommand + Quote_FromSplitwindowToSingleWindowToggleOnOff",
                    "type": "basic",
                    "from": <%= from("quote", ["left_control"]) %>,
                    "to": <%= to([["return_or_enter", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftCommand + Slash_PageUp",
                    "type": "basic",
                    "from": <%= from("slash", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["4", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "RightCommand + I_SelectNextPanel",
                    "type": "basic",
                    "from": <%= from("i", ["right_command"]) %>,
                    "to": <%= to([["open_bracket", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "RightCommand + Period_WindowMaxToggleOnOff",
                    "type": "basic",
                    "from": <%= from("period", ["right_command"]) %>,
                    "to": <%= to([["return_or_enter", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftOption + C_ClearBuffer",
                    "type": "basic",
                    "from": <%= from("c", ["left_option"]) %>,
                    "to": <%= to([["k", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftOption + I_LineUp",
                    "type": "basic",
                    "from": <%= from("i", ["left_option"]) %>,
                    "to": <%= to([["1", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftOption + O(オー)_Horizontally",
                    "type": "basic",
                    "from": <%= from("o", ["left_option"]) %>,
                    "to": <%= to([["d", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "LeftOption + U_LineDown",
                    "type": "basic",
                    "from": <%= from("u", ["left_option"]) %>,
                    "to": <%= to([["2", ["right_command", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                },
                {
                    "description": "RightOption + A_NewWindows_iterm設定済",
                    "type": "basic",
                    "from": <%= from("a", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["5", ["left_control", "left_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("iterm2") %> ]
                }
            ]
        }
    ]
}

{
    "title": "「tesuto.json.erb」でfinderのショットカットキー登録すること(Finder)",
    "rules": [
        {
            "description": "Test-{キー1} + {キー2}_ここから登録(Finder)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": <%= from("u", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["l","right_command"], ["c", "right_command"]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                }
            ]
        }
    ]
}
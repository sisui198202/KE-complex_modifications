{
    "title": "Replacekey98",
    "rules": [
                {
                    "description": "LeftAlt_Copy(Replacekey)",
                    "type": "basic",
                    "from": {
                        "key_code": "left_alt",
                        "modifiers": {
                            "optional": [
                                "caps_lock"
                            ]
                        }
                    },
                    "to": [
                        {
                            "key_code": "left_alt"
                        }
                    ],
                    "to_if_alone": [
                        {
                            "key_code": "japanese_eisuu"
                        },
                        {
                            "key_code": "c",
                            "modifiers": "right_gui"
                        }
                    ],
                    "conditions": [
                        {
                            "type": "frontmost_application_unless",
                            "bundle_identifiers": [
                                "^com.vmware.fusion$",
                                "^com.vmware.horizon$",
                                "^com.vmware.view$",
                                "^com.parallels.desktop$",
                                "^com.parallels.vm$",
                                "^com.parallels.desktop.console$",
                                "^org.virtualbox.app.VirtualBoxVM$",
                                "^com.vmware.proxyApp.",
                                "^com.parallels.winapp."
                            ]
                        }
                    ]
                }
    ]
}
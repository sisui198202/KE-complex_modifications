                {
                    "description": "RightOption + I_/Users/user/Desktop/tmp_screenshot",
                    "type": "basic",
                    "from": <%= from("i", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["quote", ["left_shift", "left_option"]]]) %>
                },
                {
                    "description": "RightOption + S_「~/Documents/Summary」PathFinderで開く or 「~/Documents/Summary」Finderで開く",
                    "type": "basic",
                    "from": <%= from("s", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["hyphen", ["right_shift", "right_command"]]]) %>

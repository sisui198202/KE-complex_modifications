                {
                    "description": "Fn + U_WindowLeftUp",
                    "type": "basic",
                    "from": <%= from("u", ["fn"], ["caps_lock"]) %>,
                    "to": <%= to([["6", "right_option"]]) %>
                },
                {
                    "description": "Fn + Y_WindowLeftTwo-thirds",
                    "type": "basic",
                    "from": <%= from("y", ["fn"], ["caps_lock"]) %>,
                    "to": <%= to([["e", ["right_control", "right_option"]]]) %>
                }
            ]
        }
    ]
}

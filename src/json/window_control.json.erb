{
    "title": "WindowControlSummary98",
    "rules": [
        {
            "description": "WindowsControlSummary98",
            "manipulators": [
                {
                    "description": "RightCommand + P_RightHalfWindowMove",
                    "type": "basic",
                    "from": <%= from("p", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["3", ["right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "RightCommand + Period_MaxWindow",
                    "type": "basic",
                    "from": <%= from("period", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["f", ["right_control", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + D_~/Desktop/",
                    "type": "basic",
                    "from": <%= from("d", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["d", ["right_shift", "right_command"]]]) %>
                },
                {
                    "description": "LeftOption + H_ExcelActiveWindow",
                    "type": "basic",
                    "from": <%= from("h", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["3", ["left_shift", "left_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + J_VivaldiActiveWindow",
                    "type": "basic",
                    "from": <%= from("j", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["4", ["left_shift", "left_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + K_VscodeActiveWindow",
                    "type": "basic",
                    "from": <%= from("k", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["5", ["left_shift", "left_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + L_KindleActiveWindow",
                    "type": "basic",
                    "from": <%= from("l", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["hyphen", ["left_shift", "left_option"]]]) %>
                },
                {
                    "description": "LeftOption + M_Active_~/Googleドライブ/",
                    "type": "basic",
                    "from": <%= from("m", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= set_shell_command(["open -a 'Path Finder.app' '/Users/user/Library/CloudStorage/GoogleDrive-aruke570209@gmail.com/マイドライブ/'"]) %>
                },
                {
                    "description": "LeftOption + N_Active_~/Dropbox/",
                    "type": "basic",
                    "from": <%= from("n", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= set_shell_command(["open -a 'Path Finder.app' '/Users/user/Dropbox'"]) %>
                },
                {
                    "description": "LeftOption + Quote_PreviewActiveWindow",
                    "type": "basic",
                    "from": <%= from("quote", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["equal_sign", ["left_shift","left_option"]]]) %>
                },
                {
                    "description": "LeftOption + Semicolon_PathfinderActiveWindow",
                    "type": "basic",
                    "from": <%= from("semicolon", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["2", ["left_shift", "left_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %> ]
                },
                {
                    "description": "LeftOption + slash_FinderActiveWindow",
                    "type": "basic",
                    "from": <%= from("slash", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["grave_accent_and_tilde", ["left_shift","left_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_unless("virtual_machine") %>]
                },
                {
                    "description": "RightOption + D_~/Documents",
                    "type": "basic",
                    "from": <%= from("d", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["8", ["right_option", "right_command"]]]) %>
                },
                {
                    "description": "RightOption + G_SafariActiveWindow",
                    "type": "basic",

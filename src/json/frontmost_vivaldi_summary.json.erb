{
    "title": "FrontmostIfVivaldi_summary991",
    "rules": [
        {
            "description": "FrontmostIfVivaldi_summary991",
            "manipulators": [
                {
                    "description": "A_新しいタブを開く",
                    "type": "basic",
                    "from": <%= from("a", ["caps_lock"]) %>,
                    "to": <%= to([["n", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "C_タブを複製",
                    "type": "basic",
                    "from": <%= from("c", ["caps_lock"]) %>,
                    "to": <%= to([["f12", ["right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "E_Reload",
                    "type": "basic",
                    "from": <%= from("e", ["caps_lock"]) %>,
                    "to": <%= to([["r", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "W_新しいウィンドウで開く",
                    "type": "basic",
                    "from": <%= from("w", ["caps_lock"]) %>,
                    "to": <%= to([["a", ["left_option","right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftCommand + openbracket_プロジェクト内に存在するファイルを指定して開く",
                    "type": "basic",
                    "from": <%= from("open_bracket", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["p", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftCommand + T_ドックの位置変更",
                    "type": "basic",
                    "from": <%= from("t", ["left_control"], ["caps_lock"]) %>,
                    "to": <%= to([["d", ["right_command", "right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftCommand + U_undo(Vivaldi)",
                    "type": "basic",
                    "from": <%= from("u", ["left_control"]) %>,
                    "to": <%= to([["delete_or_backspace"]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "RightCommand + H_Reload(Vivaldi)",
                    "type": "basic",
                    "from": <%= from("h", ["right_command"]) %>,
                    "to": <%= to([["r", ["right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "RightCommand + quote_閉じたタブを再度開く",
                    "type": "basic",
                    "from": <%= from("quote", ["right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["t", ["right_shift", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + A_プライベートウィンドウを開く",
                    "type": "basic",
                    "from": <%= from("a", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["n", ["right_shift", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + B_Bookmarkナビゲーショントグル",
                    "type": "basic",
                    "from": <%= from("b", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["b", ["right_option", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + C_タブを複製",
                    "type": "basic",
                    "from": <%= from("c", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["f12", ["right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "x:LeftOption + F_Title & URL Picker",
                    "type": "basic",
                    "from": <%= from("f", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["9",["right_shift", "right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + N_ノードのスクリーンショットをキャプチャ",
                    "type": "basic",
                    "from": <%= from("n", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["7", ["right_shift","right_command"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + openbracket_コマンドパレット",
                    "type": "basic",
                    "from": <%= from("open_bracket", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["p", ["right_command", "right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftOption + U_検索バーアクティヴ",
                    "type": "basic",
                    "from": <%= from("u", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["l","right_command"], ["c", "right_command"]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "RightOption + A_タブを新しいウィンドウに移動",
                    "type": "basic",
                    "from": <%= from("a", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= to([["hyphen", ["right_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                },
                {
                    "description": "LeftShift + RightCommand + H_ハードキャッシュ",
                    "type": "basic",
                    "from": <%= from("h", ["left_shift", "right_command"], ["caps_lock"]) %>,
                    "to": <%= to([["delete_or_backspace", ["right_command", "right_shift"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("vivaldi") %> ]
                }
            ]
        }
    ]
}

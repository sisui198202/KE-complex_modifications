{
    "title": "FrontmostIfFinder_summary2",
    "rules": [
        {
            "description": "FrontmostIfFinder_summary2",
            "manipulators": [
                {
                    "description": "LeftOption + Y_リスト(Finder)",
                    "type": "basic",
                    "from": <%= from("y", ["left_option"]) %>,
                    "to": <%= to([["2", ["left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "LeftOption + i_親ディレクトリへ",
                    "type": "basic",
                    "from": <%= from("i", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["up_arrow", ["right_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "RightOption + A_新規Finderウィンドウ",
                    "type": "basic",
                    "from": <%= from("a", ["right_option"]) %>,
                    "to": <%= to([["5", ["left_shift","left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %>]
                },
                {
                    "description": "RightOption + S_マイドライブ/Summary",
                    "type": "basic",
                    "from": <%= from("s", ["right_option"], ["caps_lock"]) %>,
                    "to": <%= set_shell_command(["open -a 'Finder' '/Users/user/Library/CloudStorage/GoogleDrive-aruke570209@gmail.com/マイドライブ/Summary'"]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %>]
                },
                {
                    "description": "LeftOption + N_Dropbox",
                    "type": "basic",
                    "from": <%= from("n", ["left_option"]) %>,
                    "to": <%= set_shell_command(["open -a 'Finder' /Users/user/Dropbox"]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "RightCommand + L_前のタブを選択",
                    "type": "basic",
                    "from": <%= from("l", ["right_gui"]) %>,
                    "to": <%= to([["1", ["left_shift","left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "RightCommand + セミコロン_次のタブを選択",
                    "type": "basic",
                    "from": <%= from("semicolon", ["right_gui"]) %>,
                    "to": <%= to([["2", ["left_shift","left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "LeftOption + M_GoogleDrive",
                    "type": "basic",
                    "from": <%= from("m", ["left_option"]) %>,
                    "to": <%= to([["3", ["left_shift","left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "LeftCommand + Z_最近の項目",
                    "type": "basic",
                    "from": <%= from("z", ["left_control"]) %>,
                    "to": <%= to([["4", ["left_shift","left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "LeftOption + U_カラム",
                    "type": "basic",
                    "from": <%= from("u", ["left_option"]) %>,
                    "to": <%= to([["3", ["left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]

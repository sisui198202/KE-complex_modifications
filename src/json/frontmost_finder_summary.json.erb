                {
                    "description": "Fn + Y_WindowLeftTwo-thirds",
                    "type": "basic",
                    "from": <%= from("y", ["right_control"], ["caps_lock"]) %>,
                    "to": <%= to([["e", ["right_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]

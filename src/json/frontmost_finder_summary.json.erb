                {
                    "description": "LeftCommand + オウ_デュアルモードの切替",
                    "type": "basic",
                    "from": <%= from("o", ["left_control"]) %>,
                    "to": <%= to([["u", ["left_gui"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "LeftCommand + T_サイドバー切替",
                    "type": "basic",
                    "from": <%= from("t", ["left_control"]) %>,
                    "to": <%= to([["s", ["left_gui","left_control"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "RightCommand + A_新規タブ作成",
                    "type": "basic",
                    "from": <%= from("a", ["right_gui"]) %>,
                    "to": <%= to([["t", ["left_shift","left_control"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "RightCommand + i_アクティブなパネルの切替",
                    "type": "basic",
                    "from": <%= from("i", ["right_gui"]) %>,

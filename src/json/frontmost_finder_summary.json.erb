                {
                    "description": "Fn + Comma_WindowCenter",
                    "type": "basic",
                    "from": <%= from("comma", ["right_control"], ["caps_lock"]) %>,
                    "to": <%= to([["c", ["right_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                }
            ]
        }
    ]
}
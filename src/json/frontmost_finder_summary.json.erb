                {
                    "description": "Fn + O_WindowRightTwo-thirds",
                    "type": "basic",
                    "from": <%= from("o", ["right_control"], ["caps_lock"]) %>,
                    "to": <%= to([["t", ["right_control", "right_option"]]]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]

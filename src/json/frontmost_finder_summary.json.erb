                    "to": <%= set_shell_command(["touch '/Users/user/Desktop/iCollections/TmpFile/z.txt'"]) %>,
                    "conditions": [ <%= frontmost_application_if("finder") %> ]
                },
                {
                    "description": "Fn + U_WindowLeftUp",
                    "type": "basic",
                    "from": <%= from("u", ["right_control"], ["caps_lock"]) %>,

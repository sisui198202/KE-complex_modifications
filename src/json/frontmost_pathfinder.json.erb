{
    "title": "FrontmostIfPathFinder",
    "rules": [
        {
            "description": "{キー1} + {キー2}_ここから登録(PathFinder)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": <%= from("u", ["left_option"], ["caps_lock"]) %>,
                    "to": <%= to([["l","right_command"], ["c", "right_command"]]) %>,
                    "conditions": [ <%= frontmost_application_if("pathFinder") %> ]
                }
            ]
        }
    ]
}